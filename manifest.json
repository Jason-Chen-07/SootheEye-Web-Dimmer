{
  "manifest_version": 3,
  "name": "Smart Bright Dark Mode",
  "version": "0.1.0",
  "description": "Detect bright pages and apply a bright dark mode.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart Bright Dark Mode"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
